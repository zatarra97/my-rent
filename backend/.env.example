# Backend myRent — variabili d'ambiente per lo sviluppo locale (src/dev.ts).
# In Lambda queste sono iniettate da Pulumi (backend/infra) — non modificare in console.

PORT=3010

# Database — RDS shared-db (schema myrent)
DB_HOST=shared-db2ac789f.cny446ao40k7.eu-north-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=
DB_DATABASE=myrent

# Password condivisa dell'app (validata dal middleware requirePassword)
APP_PASSWORD=

# S3 allegati (bucket privato)
S3_ALLEGATI_BUCKET=myrent-allegati-zatarra97
S3_REGION=eu-north-1

# CORS — origini consentite (CSV)
CORS_FRONTEND=http://localhost:5173

NODE_ENV=development
